{
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    "node_modules/**",
    "**/node_modules/**",
    "packages/**",
    "**/packages/**",
    "vendor/**",
    "**/vendor/**",
    "dist/**",
    "build/**",
    ".git/**",
    "**/.terraform/**",
    "**/.terraform.lock.hcl",
    ".vscode/**",
    ".github/copilot-instructions.md",
    "**/*.min.js",
    "**/*.min.css",
    ".mega-linter.yml",
    "package-lock.json",
    "**/package-lock.json",
    "Cargo.lock",
    "**/Cargo.lock",
    "CHANGELOG.md",
    "logs/**",
    "docs/docusaurus/build/**",
    "docs/docusaurus/coverage/**",
    "dependency-pinning-artifacts/**",
    "evals/results/**",
    "evals/beval/**/results/**"
  ],
  "ignoreRegExpList": [
    "/#.*/g",
    "/^authors?:.*(?:\\r?\\n\\s*-.*)*$/gmi",
    "/\\*\\*[A-Za-z]\\*\\*[a-z]+/g"
  ],
  "dictionaryDefinitions": [
    {
      "name": "azure-services",
      "path": "./.cspell/azure-services.txt"
    },
    {
      "name": "microsoft-sample-companies",
      "path": "./.cspell/microsoft-sample-companies.txt"
    },
    {
      "name": "industry-acronyms",
      "path": "./.cspell/industry-acronyms.txt"
    },
    {
      "name": "general-technical",
      "path": "./.cspell/general-technical.txt"
    }
  ],
  "dictionaries": [
    "k8s",
    "docker",
    "rust",
    "data-science",
    "design-thinking",
    "aws",
    "terraform",
    "azure-services",
    "microsoft-sample-companies",
    "industry-acronyms",
    "general-technical"
  ],
  "words": [
    "activedescendant",
    "agentic",
    "aoda",
    "atheris",
    "beval",
    "behaviour",
    "behavioural",
    "brainwriting",
    "clusterfuzzlite",
    "collab",
    "cosign",
    "cursored",
    "dogfooding",
    "easyops",
    "evals",
    "fetchone",
    "figjam",
    "graphify",
    "graphifyy",
    "hideable",
    "idor",
    "learning",
    "networkidle",
    "normaliz",
    "packageable",
    "parseable",
    "prval",
    "scorecard",
    "Sigstore",
    "skillmd",
    "SLSA",
    "smol",
    "SSSC",
    "sssc",
    "subcat",
    "uncited",
    "underspecified",
    "vally",
    "vyta",
    "watchlist",
    "whiteboarding",
    "wireframes",
    "ystatement",
    "πρᾶξις",
    "ˈpræksɪs"
  ],
  "reporters": [
    "default",
    [
      "@cspell/cspell-json-reporter",
      {
        "outFile": "logs/cspell-results.json"
      }
    ]
  ]
}
