{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/microsoft/hve-core/main/scripts/linting/schemas/accessibility-state.schema.json",
  "title": "Accessibility Planner State Schema",
  "description": "Schema for Accessibility Planner state.json files under .copilot-tracking/accessibility-plans/{slug}/.",
  "type": "object",
  "required": [
    "slug",
    "createdAt",
    "updatedAt",
    "currentPhase",
    "disclaimerShownAt",
    "surfaces",
    "jurisdictions",
    "frameworks"
  ],
  "additionalProperties": false,
  "properties": {
    "slug": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Kebab-case planner slug used as the directory name"
    },
    "version": {
      "type": "string",
      "description": "State document schema version (semver)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the planner state was first created"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the planner state was most recently written"
    },
    "currentPhase": {
      "type": "string",
      "enum": [
        "scoping",
        "surfaceAssessment",
        "standardsMapping",
        "gapAnalysis",
        "backlogGeneration",
        "reviewHandoff"
      ],
      "description": "Active accessibility planner phase"
    },
    "disclaimerShownAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[+-][0-9]{2}:[0-9]{2})$",
      "description": "ISO-8601 timestamp when the Accessibility Planning disclaimer was first rendered to the user"
    },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "web",
          "mobile-web",
          "hybrid-mobile",
          "native",
          "desktop",
          "content",
          "hardware",
          "voice",
          "authoring-tool"
        ]
      },
      "description": "Product surface kinds in scope for the planner session"
    },
    "jurisdictions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Regulatory jurisdictions in scope (e.g., US, EU, CA, UK, AU)"
    },
    "frameworks": {
      "type": "array",
      "items": { "$ref": "#/$defs/frameworkRef" },
      "description": "Accessibility framework skills registered for this planner session"
    },
    "suppressedControls": {
      "type": "array",
      "items": { "$ref": "#/$defs/suppressedControl" },
      "description": "Per-control opt-outs marked Not Applicable for this planner session"
    },
    "riskClassification": { "$ref": "#/$defs/riskClassification" },
    "scoping": { "$ref": "#/$defs/phaseBlock" },
    "surfaceAssessment": { "$ref": "#/$defs/phaseBlock" },
    "standardsMapping": { "$ref": "#/$defs/phaseBlock" },
    "gapAnalysis": { "$ref": "#/$defs/phaseBlock" },
    "backlogGeneration": { "$ref": "#/$defs/phaseBlock" },
    "reviewHandoff": { "$ref": "#/$defs/phaseBlock" }
  },
  "$defs": {
    "frameworkRef": {
      "type": "object",
      "required": ["frameworkId", "version"],
      "additionalProperties": false,
      "properties": {
        "frameworkId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Framework identifier (e.g., wcag-2-2, en-301-549, ada-section-508)"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "profile": {
          "type": ["string", "null"],
          "description": "Optional profile or conformance level (e.g., AA, AAA)"
        },
        "disabled": {
          "type": "boolean",
          "default": false,
          "description": "When true, the planner skips this framework. Excluded frameworks appear only in the handoff audit appendix."
        },
        "disabledReason": {
          "type": "string",
          "minLength": 1,
          "description": "Required when disabled is true. Free-form rationale recorded for the handoff audit appendix."
        },
        "disabledAtPhase": {
          "type": "string",
          "enum": [
            "scoping",
            "surfaceAssessment",
            "standardsMapping",
            "gapAnalysis",
            "backlogGeneration",
            "reviewHandoff"
          ],
          "description": "Phase at which the framework was disabled."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "disabled": { "const": true } }, "required": ["disabled"] },
          "then": { "required": ["disabledReason", "disabledAtPhase"] }
        }
      ]
    },
    "suppressedControl": {
      "type": "object",
      "required": ["controlId", "frameworkId", "naReason"],
      "additionalProperties": false,
      "properties": {
        "controlId": {
          "type": "string",
          "minLength": 1,
          "description": "Control identifier matching one entry in the framework skill phaseMap"
        },
        "frameworkId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Framework identifier owning the suppressed control"
        },
        "naReason": {
          "type": "string",
          "minLength": 1,
          "description": "User-supplied rationale for marking the control Not Applicable"
        }
      }
    },
    "riskClassification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "binary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "regulatedJurisdiction": {
              "type": "boolean",
              "description": "True when at least one in-scope jurisdiction imposes statutory accessibility obligations on the product"
            }
          }
        },
        "categorical": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "surfaceKind": {
              "type": "string",
              "enum": [
                "web",
                "mobile-web",
                "hybrid-mobile",
                "native",
                "desktop",
                "content",
                "hardware",
                "voice",
                "authoring-tool"
              ]
            }
          }
        },
        "continuous": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "audienceSize": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "min": { "type": "integer", "minimum": 0 },
                "max": { "type": "integer", "minimum": 0 }
              }
            }
          }
        },
        "suggestedDepthTier": {
          "type": ["string", "null"],
          "enum": ["basic", "standard", "deep", null]
        }
      }
    },
    "phaseBlock": {
      "type": "object",
      "additionalProperties": true,
      "description": "Per-phase planner state. Fields evolve in-phase without schema churn."
    }
  }
}
