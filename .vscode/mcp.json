{
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "workiq": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@microsoft/workiq",
        "mcp"
      ]
    },
    "mural": {
      "type": "stdio",
      "command": "pwsh",
      "args": [
        "-File",
        "./scripts/mcp/Start-MuralMcp.ps1"
      ]
    }
  }
}